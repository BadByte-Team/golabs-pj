# Configuración de la API — golabs-api
# Copiar este archivo a .env y completar los valores antes de iniciar.
#
# Generar JWT_SECRET con:   openssl rand -hex 32
# NO commitear el archivo .env con valores reales.

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_HOST=localhost        # Usar 'db' si la API corre dentro de Docker Compose
DB_PORT=3306
DB_NAME=golabs
DB_USER=golabs_user
DB_PASSWORD=CAMBIAR_ESTO
DB_ROOT_PASSWORD=CAMBIAR_ESTO_ROOT  # Password del root de MariaDB (distinto al usuario de app)

# Pool de conexiones (opcionales — defaults razonables para producción)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CAMBIAR_ESTO_con_openssl_rand_hex_32
JWT_ISSUER=golabs-api
JWT_EXP_MINUTES=15       # Duración del access token en minutos

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos, separados por coma. Ejemplo producción:
# ALLOWED_ORIGINS=https://app.tu-dominio.com
ALLOWED_ORIGINS=http://localhost:3000
