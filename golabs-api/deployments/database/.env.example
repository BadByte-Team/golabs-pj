# Configuración de MariaDB — golabs-api (BD standalone)
# Copiar a .env y completar antes de ejecutar 'make up'.
#
# NO commitear este archivo con valores reales.

MARIADB_ROOT_PASSWORD=CAMBIAR_ESTO  # Password del usuario root de MariaDB
MARIADB_DATABASE=golabs             # Base de datos creada automáticamente al arrancar
MARIADB_USER=golabs_user            # Usuario de aplicación (no root)
MARIADB_PASSWORD=CAMBIAR_ESTO       # Password del usuario de aplicación
MARIADB_PORT=3306                   # Puerto expuesto al host
